<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Libraro" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/bg_screen</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="colorControlActivated">@android:color/black</item>
        <item name="android:textColorHighlight">#4D000000</item>
    </style>

    <style name="Theme.Libraro" parent="Base.Theme.Libraro" />

    <!-- Material Date Picker Theme -->
    <style name="CustomDatePickerTheme" parent="ThemeOverlay.MaterialComponents.MaterialCalendar">
        <item name="colorPrimary">@color/app_color_1</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorAccent">@color/app_color_1</item>
    </style>

    <style name="HintTextAppearance" parent="TextAppearance.Design.Hint">
        <item name="android:fontFamily">@font/outfit_regular</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/edit_text_hint_color_545454</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/box_stroke_color</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="cursorColor">@color/black</item>
        <item name="hintTextColor">@color/edit_text_hint_color_545454</item>
        <item name="hintTextAppearance">@style/HintTextAppearance</item>
    </style>

    <style name="BottomNav.Active" parent="TextAppearance.AppCompat.Caption">
        <item name="android:fontFamily">@font/outfit_medium</item>
    </style>

    <style name="BottomNav.Inactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:fontFamily">@font/outfit_regular</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

</resources>
